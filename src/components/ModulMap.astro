---
// Modul-térkép — a teljes BoxBook képességtárgyalás 8 csoportban.
// Mindegyik csoport a valódi CRM admin moduljaiból származik (auto-detailing/src/app/admin/*).
// Lumora-elv: "mindent egy login mögé" - egy ablak, egy ár, 60+ funkció.

const groups = [
  {
    icon: "calendar-clock",
    tone: "leaf",
    heading: "Foglalás",
    items: ["Mosóállás-alapú timeline", "5 lépéses online flow", "Aktív/passzív fázisok", "Slot-finder algoritmus", "Várólista + auto-újraajánlat", "Visszatérő foglalások", "Lemondási link emailben"],
  },
  {
    icon: "users",
    tone: "cyan",
    heading: "Vendég & Jármű",
    items: ["Vendég-profil + tier", "Jármű 1:N (rendszám, márka)", "Javítási előzmény", "Magic-link bejelentkezés", "Saját ügyfél-fiók", "Önkiszolgáló lemondás"],
  },
  {
    icon: "receipt",
    tone: "lime",
    heading: "Pénzügy",
    items: ["Árazási mátrix (kategória × szolgáltatás)", "Ajándékkártya kezelés", "Kuponok + akciók", "Speciális ajánlatok", "Hűségpont rendszer", "Bérletek (5+1, stb.)"],
  },
  {
    icon: "package",
    tone: "leaf",
    heading: "Szolgáltatás",
    items: ["Kategóriák + alkategóriák", "Aktív/passzív szegmens-tervezés", "Extra szolgáltatások (add-on)", "Csomagok (bundle)", "Upsell-szabályok", "Termékek értékesítése"],
  },
  {
    icon: "megaphone",
    tone: "cyan",
    heading: "Marketing",
    items: ["Értékelés-gyűjtő flow", "Email értesítések + sablon", "SMS log + kampány", "Visszahívó listák", "Lead-rendszer", "Google review-kérés"],
  },
  {
    icon: "settings-2",
    tone: "lime",
    heading: "Üzemeltetés",
    items: ["Munkatársak + munkaidő", "Box-szintű nyitvatartás", "Csapat-szerepek (ADMIN/STAFF)", "Időszakos szabadság", "Záró napok / ünnepek", "Google Naptár sync per-fő"],
  },
  {
    icon: "bar-chart-3",
    tone: "leaf",
    heading: "Riportok",
    items: ["Bevétel-trend (havi)", "Service-mix bontás", "Ops-status valós időben", "KPI dashboard", "Foglalás-export CSV", "Audit napló"],
  },
  {
    icon: "shield-check",
    tone: "cyan",
    heading: "SaaS & Biztonság",
    items: ["Multi-tenant (több szalon)", "Custom domain + branding", "Téma-preset (6 szín)", "Per-tenant napi backup", "Magic-link auth (NextAuth)", "Rate-limit védelem"],
  },
];

const toneStyles: Record<string, { iconBg: string; iconText: string; ring: string; chipBg: string; chipText: string }> = {
  leaf: { iconBg: "bg-leaf-50", iconText: "text-leaf-700", ring: "ring-leaf-200", chipBg: "bg-leaf-50", chipText: "text-leaf-700" },
  cyan: { iconBg: "bg-cyan-50", iconText: "text-cyan-700", ring: "ring-cyan-200", chipBg: "bg-cyan-50", chipText: "text-cyan-700" },
  lime: { iconBg: "bg-lime-50", iconText: "text-lime-700", ring: "ring-lime-200", chipBg: "bg-lime-50", chipText: "text-lime-700" },
};
---

<section id="modul-terkep" class="relative bg-ink-50 border-y border-ink-200">
  <div class="mx-auto max-w-7xl px-5 lg:px-8 py-24 lg:py-32">
    <div class="max-w-3xl mx-auto text-center fade-up">
      <span class="inline-flex items-center gap-2 rounded-full bg-white ring-1 ring-ink-200 text-ink-700 px-3 py-1 text-[11px] font-bold tracking-widest uppercase">
        <i data-lucide="layout-grid" class="w-3 h-3"></i>
        Modul-térkép
      </span>
      <h2 class="mt-5 text-4xl lg:text-6xl font-extrabold tracking-tightest text-balance leading-[1.02]">
        60+ funkció. <span class="grad-text-strong">Egy login. Egy ár.</span>
      </h2>
      <p class="mt-5 text-ink-600 text-lg text-pretty">
        Foglalástól a riportig, vendég-profil-tól a Google-naptárig. Gyors áttekintés mindenről, amit a BoxBook kezel — magyar pénzügyi környezetre szabva.
      </p>
    </div>

    <div class="mt-14 grid sm:grid-cols-2 lg:grid-cols-4 gap-3">
      {groups.map((g, idx) => {
        const t = toneStyles[g.tone] ?? toneStyles.leaf;
        return (
          <article class="fade-up rounded-2xl bg-white ring-1 ring-ink-200 p-5 lg:p-6 hover:-translate-y-0.5 hover:shadow-[0_18px_40px_-20px_rgba(9,9,11,0.18)] transition-all" style={`transition-delay: ${idx * 30}ms`}>
            <div class="flex items-center justify-between">
              <span class:list={["grid place-items-center w-10 h-10 rounded-xl ring-1", t.iconBg, t.iconText, t.ring]}>
                <i data-lucide={g.icon} class="w-5 h-5"></i>
              </span>
              <span class="text-[10px] font-extrabold uppercase tracking-widest text-ink-400">{g.items.length}</span>
            </div>
            <h3 class="mt-4 text-base font-extrabold text-ink-900 tracking-tighter2">{g.heading}</h3>
            <ul class="mt-3 flex flex-wrap gap-1.5">
              {g.items.map((item) => (
                <li class:list={["inline-flex items-center rounded-full px-2 py-0.5 text-[11px] font-semibold", t.chipBg, t.chipText]}>{item}</li>
              ))}
            </ul>
          </article>
        );
      })}
    </div>

    <p class="mt-10 text-center text-sm font-medium text-ink-600">
      60+ funkció · egyetlen előfizetésben · magyar fejlesztés & support
    </p>
  </div>
</section>
