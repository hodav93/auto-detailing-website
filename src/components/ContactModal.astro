---
// Dialog-modal — minden form-CTA átkötve `data-contact-source` attribútummal
---

<dialog id="contact-modal" class="bg-transparent backdrop:bg-ink-900/60 backdrop:backdrop-blur-sm p-0 m-auto rounded-2xl w-full max-w-lg">
  <div class="relative bg-white rounded-2xl shadow-[0_40px_100px_-30px_rgba(9,9,11,0.5)] overflow-hidden">
    <div class="relative grad-bg p-6">
      <button type="button" data-close-modal class="absolute top-4 right-4 grid place-items-center w-8 h-8 rounded-full bg-ink-900/10 text-ink-900 hover:bg-ink-900/20 transition-colors">
        <i data-lucide="x" class="w-4 h-4"></i>
      </button>
      <div class="text-[10px] font-extrabold tracking-widest text-ink-900/60 uppercase" id="contact-modal-eyebrow">Kapcsolat</div>
      <h2 class="mt-1 text-2xl font-extrabold tracking-tighter2 text-ink-900" id="contact-modal-title">Vegyük fel a kapcsolatot</h2>
      <p class="mt-1.5 text-sm text-ink-900/70" id="contact-modal-desc">Munkaidőben ~15 percen belül válaszolunk.</p>
    </div>

    <form id="contact-form" class="p-6 space-y-3">
      <input type="hidden" name="source" id="contact-source-input" value="CONTACT_FORM" />
      <input type="text" name="website" tabindex="-1" autocomplete="off" class="absolute opacity-0 pointer-events-none -left-[9999px]" aria-hidden="true" />

      <div class="grid sm:grid-cols-2 gap-3">
        <div>
          <label class="text-[11px] font-bold uppercase tracking-widest text-ink-500">Név</label>
          <input type="text" name="name" maxlength="200" class="mt-1 w-full rounded-lg bg-ink-50 ring-1 ring-ink-200 px-3.5 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-leaf-400 focus:bg-white transition" />
        </div>
        <div>
          <label class="text-[11px] font-bold uppercase tracking-widest text-ink-500">Cég / szalon</label>
          <input type="text" name="company" maxlength="200" class="mt-1 w-full rounded-lg bg-ink-50 ring-1 ring-ink-200 px-3.5 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-leaf-400 focus:bg-white transition" />
        </div>
      </div>

      <div class="grid sm:grid-cols-2 gap-3">
        <div>
          <label class="text-[11px] font-bold uppercase tracking-widest text-ink-500">Email <span class="text-red-500">*</span></label>
          <input type="email" name="email" required maxlength="200" class="mt-1 w-full rounded-lg bg-ink-50 ring-1 ring-ink-200 px-3.5 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-leaf-400 focus:bg-white transition" />
        </div>
        <div>
          <label class="text-[11px] font-bold uppercase tracking-widest text-ink-500">Telefon</label>
          <input type="tel" name="phone" maxlength="40" class="mt-1 w-full rounded-lg bg-ink-50 ring-1 ring-ink-200 px-3.5 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-leaf-400 focus:bg-white transition" />
        </div>
      </div>

      <div>
        <label class="text-[11px] font-bold uppercase tracking-widest text-ink-500">Üzenet</label>
        <textarea name="message" rows="3" maxlength="3000" class="mt-1 w-full rounded-lg bg-ink-50 ring-1 ring-ink-200 px-3.5 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-leaf-400 focus:bg-white transition resize-none" placeholder="Bármi amit fontosnak tartasz hogy tudjunk a szalonodról…"></textarea>
      </div>

      <div id="contact-error" class="hidden rounded-lg bg-red-50 ring-1 ring-red-200 text-red-800 text-xs px-3 py-2"></div>
      <div id="contact-success" class="hidden rounded-lg bg-leaf-50 ring-1 ring-leaf-200 text-leaf-800 text-sm px-3 py-3">
        <b>Köszi!</b> Beérkezett — visszahívunk munkaidőben.
      </div>

      <div class="flex items-center justify-between gap-3 pt-1">
        <p class="text-[10px] text-ink-500">A küldéssel hozzájárulsz a kapcsolattartási adataid kezeléséhez.</p>
        <button type="submit" id="contact-submit" class="inline-flex items-center gap-2 rounded-full bg-ink-900 text-white px-5 py-3 text-sm font-extrabold hover:bg-ink-800 transition-colors disabled:opacity-50 shrink-0">
          <span class="contact-submit-label">Üzenet küldése</span>
          <i data-lucide="arrow-right" class="w-4 h-4"></i>
        </button>
      </div>
    </form>
  </div>
</dialog>
