---
const reviews = [
  { name: "Kovács Béla", initials: "KB", color: "grad-bg", text: "Az autóm úgy néz ki, mintha új lenne. A polírozás briliáns minőség, ráadásul időben elkészültek. 100%-ig ajánlom.", meta: "3 hete · Opel Astra", source: "Google", stars: 5, dark: false },
  { name: "Tóth Erika", initials: "TE", color: "grad-bg", text: "Évek óta itt mosatok. A foglalási rendszer 30 másodperc, és mindig ugyanaz a profi csapat. Kerámia-bevonatot is itt csináltattam, már 8 hónapja tartja a fényt.", meta: "2 hónapja · Porsche Cayenne", source: "Saját", stars: 5, dark: true },
  { name: "Nagy Péter", initials: "NP", color: "bg-cyan-500", text: "Jó ár-érték arány, gyors. Egy csillagot azért húztam le, mert a hétvégi időpontot nehéz megfogni — de ez a kereslet jele.", meta: "10 napja · Hyundai Tucson", source: "Google", stars: 4, dark: false },
];
const star = '<svg viewBox="0 0 20 20" class="w-4 h-4" fill="currentColor"><path d="M10 1l2.928 5.93 6.545.951-4.736 4.617 1.118 6.518L10 16.13l-5.855 3.077 1.118-6.518L.527 8.072l6.545-.951z"/></svg>';
---

<section id="velemenyek" class="relative">
  <div class="mx-auto max-w-7xl px-5 lg:px-8 py-24 lg:py-32">
    <div class="grid lg:grid-cols-12 gap-10 items-end mb-12">
      <div class="lg:col-span-7 fade-up">
        <span class="inline-flex items-center gap-2 rounded-full bg-leaf-50 ring-1 ring-leaf-200 text-leaf-700 px-3 py-1 text-[11px] font-bold tracking-widest uppercase">
          <i data-lucide="quote" class="w-3 h-3"></i>
          Vélemények
        </span>
        <h2 class="mt-5 text-4xl lg:text-6xl font-extrabold tracking-tightest text-balance leading-[1.02]">
          <span class="grad-text-strong">9.6 / 10</span> — amit a vendégek mondanak.
        </h2>
      </div>
      <div class="lg:col-span-5 fade-up" style="transition-delay: 80ms">
        <div class="flex items-center gap-1 text-amber-400">
          <Fragment set:html={star.repeat(5)} />
        </div>
        <div class="text-sm text-ink-600 mt-1"><b class="text-ink-900">4.83 átlag</b> · 6 értékelés · vegyes (Google + saját)</div>
      </div>
    </div>

    <div class="grid md:grid-cols-3 gap-5">
      {reviews.map((r, idx) => (
        <article class:list={[
          "fade-up rounded-2xl p-6 lg:p-7 flex flex-col relative overflow-hidden",
          r.dark ? "bg-ink-900 text-white" : "bg-leaf-50 ring-1 ring-leaf-200",
        ]} style={`transition-delay: ${idx * 40}ms`}>
          {r.dark && <div class="absolute -top-16 -right-16 w-40 h-40 grad-bg rounded-full blur-3xl opacity-30"></div>}
          <div class="relative flex items-center justify-between mb-4">
            <div class="flex items-center gap-1 text-amber-400">
              <Fragment set:html={star.repeat(r.stars) + '<span class="text-ink-200">' + star.repeat(5 - r.stars) + '</span>'} />
            </div>
            <span class:list={[
              "inline-flex items-center gap-1 rounded-full px-2 py-0.5 text-[10px] font-bold",
              r.dark ? "bg-white/10 ring-1 ring-white/15 text-white" : "bg-white ring-1 ring-leaf-200 text-leaf-700",
            ]}>
              <i data-lucide={r.source === "Google" ? "globe" : "pencil"} class="w-2.5 h-2.5"></i>
              {r.source}
            </span>
          </div>
          <p class:list={["relative leading-relaxed flex-1", r.dark ? "text-white/90" : "text-ink-800"]}>„{r.text}"</p>
          <div class="relative mt-5 flex items-center gap-3">
            <span class:list={["grid place-items-center w-10 h-10 rounded-full font-extrabold text-sm", r.color, r.color === "grad-bg" ? "text-ink-900" : "text-white"]}>{r.initials}</span>
            <div>
              <div class:list={["font-bold tracking-tighter2", r.dark ? "" : "text-ink-900"]}>{r.name}</div>
              <div class={r.dark ? "text-[11px] text-white/55" : "text-[11px] text-ink-500"}>{r.meta}</div>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
