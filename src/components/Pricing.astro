---
import { getContent, getPricing, tSync, fmtPrice } from "../lib/cms";
import { SIGNUP_URL } from "../lib/links";
const c = await getContent();
const plans = await getPricing();
const title = tSync(c, "pricing.title", "Egyszerű árazás. Bezzeg minden.");
const description = tSync(c, "pricing.description");

type PlanFeature = { title?: string; included?: boolean; bold?: boolean };
---

<section id="arazas" class="relative bg-ink-50 border-y border-ink-200">
  <div class="mx-auto max-w-7xl px-5 lg:px-8 py-24 lg:py-32">
    <div class="max-w-3xl mx-auto text-center fade-up">
      <span class="inline-flex items-center gap-2 rounded-full grad-bg text-ink-900 px-3 py-1 text-[11px] font-extrabold tracking-widest uppercase">Árazás</span>
      <h2 class="mt-5 text-4xl lg:text-6xl font-extrabold tracking-tightest text-balance leading-[1.02]">
        Egyszerű árazás. <span class="grad-text-strong">Bezzeg minden.</span>
      </h2>
      <p class="mt-5 text-ink-600 text-lg text-pretty">{description}</p>

      <div class="mt-8 inline-flex items-center bg-white ring-1 ring-ink-200 rounded-full p-1 shadow-soft">
        <button data-period="monthly" class="period-btn rounded-full px-5 py-2 text-xs font-bold bg-ink-900 text-white transition-all">Havi</button>
        <button data-period="yearly" class="period-btn rounded-full px-5 py-2 text-xs font-bold text-ink-700 hover:text-ink-900 transition-all">
          Éves <span class="inline-flex items-center gap-1 ml-1 rounded-full bg-leaf-100 text-leaf-700 ring-1 ring-leaf-200 px-1.5 py-0.5 text-[9px] font-extrabold tracking-widest uppercase">−2 hó</span>
        </button>
      </div>
    </div>

    <div class="mt-14 grid lg:grid-cols-3 gap-5 max-w-6xl mx-auto items-stretch">
      {plans.map((plan) => {
        const isHighlighted = plan.highlighted;
        const features = (plan.features as PlanFeature[]) ?? [];
        return (
          <article class:list={[
            "fade-up rounded-3xl p-7 lg:p-8 relative flex flex-col",
            isHighlighted
              ? "bg-ink-900 text-white shadow-[0_40px_100px_-30px_rgba(9,9,11,0.4)] lg:-mt-4 overflow-hidden"
              : "bg-white ring-1 ring-ink-200",
          ]}>
            {isHighlighted && (
              <>
                <div class="absolute -top-20 -right-20 w-72 h-72 grad-bg rounded-full blur-3xl opacity-30"></div>
                <div class="absolute -bottom-20 -left-20 w-64 h-64 grad-bg rounded-full blur-3xl opacity-20"></div>
                {plan.badge && (
                  <span class="absolute top-7 right-7 rounded-full grad-bg text-ink-900 px-3 py-1 text-[10px] font-extrabold tracking-widest uppercase shadow-[0_8px_20px_-6px_rgba(132,204,22,0.6)]">{plan.badge}</span>
                )}
              </>
            )}

            <div class="relative flex items-center justify-between">
              <span class:list={[
                "rounded-full px-3 py-1 text-[10px] font-extrabold tracking-widest uppercase",
                isHighlighted ? "bg-white/10 ring-1 ring-white/15 text-white" : (plan.slug === "halozat" ? "bg-cyan-50 ring-1 ring-cyan-200 text-cyan-700" : "bg-ink-50 ring-1 ring-ink-200 text-ink-700"),
              ]}>{plan.name}</span>
              <i data-lucide={plan.slug === "starter" ? "rocket" : plan.slug === "pro" ? "sparkles" : "building"} class={isHighlighted ? "w-5 h-5 text-leaf-400" : "w-5 h-5 text-ink-400"}></i>
            </div>

            {/* Persona-match chip — segít a látogatónak elhelyezni magát */}
            <div class:list={[
              "relative mt-3 inline-flex items-center gap-1.5 rounded-full px-2.5 py-1 text-[10px] font-bold uppercase tracking-widest",
              isHighlighted ? "bg-leaf-400/15 text-leaf-300 ring-1 ring-leaf-400/30" :
                plan.slug === "starter" ? "bg-leaf-50 text-leaf-700 ring-1 ring-leaf-200" :
                "bg-cyan-50 text-cyan-700 ring-1 ring-cyan-200",
            ]}>
              <i data-lucide={plan.slug === "starter" ? "user" : plan.slug === "pro" ? "users" : "building-2"} class="w-3 h-3"></i>
              {plan.slug === "starter" ? "1 mosó · egyfős" : plan.slug === "pro" ? "2–5 mosó · csapat" : "2+ telephely · lánc"}
            </div>

            {plan.tagline && (
              <p class:list={["mt-3 text-sm leading-relaxed", isHighlighted ? "text-white/75" : "text-ink-600"]}>{plan.tagline}</p>
            )}

            <div class="relative mt-6 flex items-baseline gap-2">
              {plan.monthlyPriceHuf === null ? (
                <span class:list={["text-5xl font-extrabold tracking-tightest leading-none", isHighlighted ? "grad-text" : "text-ink-900"]}>Egyedi</span>
              ) : (
                <>
                  <span class:list={["text-5xl lg:text-6xl font-extrabold tracking-tightest leading-none", isHighlighted ? "grad-text" : "text-ink-900"]}>
                    <span class="price-monthly">{fmtPrice(plan.monthlyPriceHuf)}</span><span class="price-yearly hidden">{fmtPrice(plan.yearlyPriceHuf)}</span>
                  </span>
                  <span class:list={["text-base font-bold", isHighlighted ? "text-white/70" : "text-ink-500"]}>Ft / hó</span>
                </>
              )}
            </div>
            {plan.monthlyPriceHuf !== null && (
              <p class:list={["mt-1 text-xs", isHighlighted ? "text-white/55" : "text-ink-500"]}>
                <span class="price-monthly">Plusz ÁFA · havonta számlázva</span>
                <span class="price-yearly hidden">Plusz ÁFA · évente számlázva ({fmtPrice((plan.yearlyPriceHuf ?? 0) * 12)} Ft / év)</span>
              </p>
            )}
            {plan.monthlyPriceHuf === null && (
              <p class={isHighlighted ? "mt-1 text-xs text-white/55" : "mt-1 text-xs text-ink-500"}>Hívás-alapú árazás · per szalon árszámítás</p>
            )}

            {/* Founder pricing badge — csak a Pro csomagon, sürgetés */}
            {plan.slug === "pro" && (
              <div class="relative mt-3 inline-flex items-center gap-1.5 rounded-full bg-gradient-to-r from-amber-400/20 to-rose-400/20 ring-1 ring-amber-400/30 px-3 py-1.5 text-[10px] font-extrabold uppercase tracking-widest text-amber-300">
                <i data-lucide="flame" class="w-3 h-3"></i>
                Alapító ár · 2026 végéig
              </div>
            )}

            {/* 0 Ft setup chip — minden tier, anti-friction */}
            <div class:list={[
              "relative mt-3 inline-flex items-center gap-1.5 rounded-full px-3 py-1.5 text-[10px] font-bold tracking-widest uppercase",
              isHighlighted ? "bg-leaf-400/10 text-leaf-300 ring-1 ring-leaf-400/25" : "bg-leaf-50 text-leaf-700 ring-1 ring-leaf-200",
            ]}>
              <i data-lucide="check-circle" class="w-3 h-3"></i>
              0 Ft setup · 2–5 nap alatt élesítve
            </div>

            <ul class="relative mt-7 space-y-2.5 text-sm flex-1">
              {features.map((f) => (
                <li class:list={["flex gap-2.5", f.included === false && (isHighlighted ? "text-white/40" : "text-ink-400")]}>
                  {f.included === false ? (
                    <i data-lucide="x" class="w-4 h-4 mt-0.5 shrink-0"></i>
                  ) : (
                    <i data-lucide="check" class={isHighlighted ? "w-4 h-4 text-leaf-400 mt-0.5 shrink-0" : "w-4 h-4 text-leaf-600 mt-0.5 shrink-0"}></i>
                  )}
                  <span>{f.bold ? <b>{f.title}</b> : f.title}</span>
                </li>
              ))}
            </ul>

            <a
              href={plan.ctaHref ?? SIGNUP_URL}
              data-contact-source={plan.slug === "halozat" ? "NETWORK_QUOTE" : "DEMO_TRIAL"}
              class:list={[
                "relative mt-8 inline-flex items-center justify-center gap-2 rounded-full px-5 py-3 text-sm font-extrabold transition-all",
                isHighlighted
                  ? "grad-bg text-ink-900 px-5 py-3.5 hover:-translate-y-0.5 shadow-[0_20px_60px_-15px_rgba(132,204,22,0.55)]"
                  : (plan.slug === "halozat" ? "bg-cyan-600 text-white hover:bg-cyan-700" : "bg-ink-900 text-white hover:bg-ink-800"),
              ]}
            >
              {isHighlighted && <i data-lucide="play" class="w-4 h-4"></i>}
              {plan.ctaLabel ?? "Próbáld ki"}
              <i data-lucide="arrow-right" class="w-4 h-4"></i>
            </a>
            <p class:list={["mt-3 text-[11px] text-center", isHighlighted ? "text-white/55" : "text-ink-500"]}>
              {plan.slug === "halozat" ? "~24 órán belül válaszolunk" : "14 nap próba · kártyaadat nélkül"}
            </p>
          </article>
        );
      })}
    </div>

    <!-- KÉSEDELMI KÖLTSÉG mini-blokk — a vásárlási döntéspont sürgetése -->
    <div class="mt-12 max-w-6xl mx-auto fade-up rounded-2xl bg-ink-900 text-white p-6 lg:p-8 relative overflow-hidden">
      <div class="absolute inset-0 opacity-30 pointer-events-none" style="background-image: radial-gradient(at 100% 50%, rgba(220,38,38,0.30), transparent 50%);"></div>
      <div class="relative grid lg:grid-cols-12 gap-6 items-center">
        <div class="lg:col-span-7">
          <span class="inline-flex items-center gap-2 rounded-full bg-[#fef2f2]/10 text-[#fca5a5] ring-1 ring-[#fca5a5]/30 px-3 py-1 text-[11px] font-extrabold tracking-widest uppercase">
            <i data-lucide="trending-down" class="w-3 h-3"></i>
            Késedelmi költség
          </span>
          <h3 class="mt-3 text-2xl lg:text-3xl font-extrabold tracking-tighter2 leading-tight">
            „Várok még egy hónapot."<br/>
            <span class="text-[#fca5a5]">−500 000 Ft.</span>
          </h3>
          <p class="mt-3 text-sm text-white/75 leading-relaxed">
            Iparági átlagok alapján egy közepes szalon havonta ~500 000 Ft bevételt hagy a versenytárson Google-keresésen, no-show-n és a régi vendég-kopáson keresztül. Ez <b class="text-white">50× a Pro csomag havidíja</b>.
          </p>
        </div>
        <div class="lg:col-span-5 grid grid-cols-3 gap-2.5">
          <div class="rounded-xl bg-white/5 ring-1 ring-white/10 p-3 text-center">
            <div class="text-[10px] uppercase tracking-widest text-white/55 font-bold">1 hónap</div>
            <div class="mt-1 text-xl font-extrabold tracking-tighter2 text-[#fca5a5]">−500e</div>
          </div>
          <div class="rounded-xl bg-white/5 ring-1 ring-white/10 p-3 text-center">
            <div class="text-[10px] uppercase tracking-widest text-white/55 font-bold">1 negyedév</div>
            <div class="mt-1 text-xl font-extrabold tracking-tighter2 text-[#fca5a5]">−1.5M</div>
          </div>
          <div class="rounded-xl bg-[#fca5a5]/15 ring-1 ring-[#fca5a5]/30 p-3 text-center">
            <div class="text-[10px] uppercase tracking-widest text-[#fca5a5] font-bold">1 év</div>
            <div class="mt-1 text-xl font-extrabold tracking-tighter2 text-[#fca5a5]">−6M Ft</div>
          </div>
        </div>
      </div>
      <div class="relative mt-6 flex flex-wrap items-center justify-between gap-3 pt-5 border-t border-white/10">
        <p class="text-[12px] text-white/55">A számok iparági átlagok. A saját szalonod adataira pontosabb képet adunk ingyenes auditban.</p>
        <a href="#" data-contact-source="DEMO_TRIAL" class="inline-flex items-center gap-2 rounded-full grad-bg text-ink-900 px-5 py-2.5 text-sm font-extrabold hover:-translate-y-0.5 transition-transform shrink-0">
          14 nap ingyen — most kezdek
          <i data-lucide="arrow-right" class="w-4 h-4"></i>
        </a>
      </div>
    </div>

    <!-- Eredeti 2 oszlop: hívás + marketing-átvezetés -->
    <div class="mt-6 grid lg:grid-cols-12 gap-4 max-w-6xl mx-auto items-stretch">
      <div class="lg:col-span-7 fade-up rounded-2xl bg-white ring-1 ring-ink-200 p-6 lg:p-7 flex items-start gap-4">
        <span class="grid place-items-center w-12 h-12 rounded-xl grad-bg text-ink-900 shrink-0"><i data-lucide="phone" class="w-6 h-6"></i></span>
        <div class="flex-1 min-w-0">
          <h3 class="font-extrabold text-ink-900 tracking-tighter2 text-lg">Nem biztos melyik csomag?</h3>
          <p class="mt-1.5 text-sm text-ink-600 leading-relaxed">
            Egyetlen <b class="text-ink-900">30 perces telefonhívásban</b> végigmegyünk a szalonod jellemzőin, és megmondjuk őszintén — Starter, Pro, vagy egyik sem. Nem érdek, nem nyomás.
          </p>
        </div>
        <a href="#" data-contact-source="CALL_REQUEST" class="hidden sm:inline-flex items-center gap-2 rounded-full bg-ink-900 text-white px-5 py-3 text-sm font-extrabold hover:bg-ink-800 transition-colors shrink-0">
          Hívás
          <i data-lucide="arrow-right" class="w-4 h-4"></i>
        </a>
      </div>
      <div class="lg:col-span-5 fade-up rounded-2xl bg-cyan-50 ring-1 ring-cyan-200 p-6 lg:p-7 flex items-start gap-4" style="transition-delay: 80ms">
        <span class="grid place-items-center w-12 h-12 rounded-xl bg-white text-cyan-700 ring-1 ring-cyan-200 shrink-0"><i data-lucide="megaphone" class="w-6 h-6"></i></span>
        <div class="flex-1 min-w-0">
          <div class="text-[10px] uppercase tracking-widest text-cyan-700 font-extrabold">Plusz</div>
          <h3 class="font-extrabold text-ink-900 tracking-tighter2 text-lg">Marketinget is csinálunk?</h3>
          <p class="mt-1.5 text-sm text-ink-700 leading-relaxed">
            <a href="/marketing" class="font-bold text-cyan-700 hover:underline">Igen, mi kérünk →</a> Skálázási csomagok ügynökségi szinten.
          </p>
        </div>
      </div>
    </div>

    <div class="mt-6 grid sm:grid-cols-2 lg:grid-cols-4 gap-3 max-w-6xl mx-auto">
      <div class="rounded-xl bg-white ring-1 ring-ink-200 px-4 py-3.5 flex items-center gap-2.5 fade-up">
        <i data-lucide="shield-check" class="w-4 h-4 text-leaf-600 shrink-0"></i>
        <span class="text-xs text-ink-700"><b class="text-ink-900">GDPR-konform</b></span>
      </div>
      <div class="rounded-xl bg-white ring-1 ring-ink-200 px-4 py-3.5 flex items-center gap-2.5 fade-up" style="transition-delay: 30ms">
        <i data-lucide="cloud-upload" class="w-4 h-4 text-leaf-600 shrink-0"></i>
        <span class="text-xs text-ink-700"><b class="text-ink-900">Napi backup</b></span>
      </div>
      <div class="rounded-xl bg-white ring-1 ring-ink-200 px-4 py-3.5 flex items-center gap-2.5 fade-up" style="transition-delay: 60ms">
        <i data-lucide="refresh-cw" class="w-4 h-4 text-leaf-600 shrink-0"></i>
        <span class="text-xs text-ink-700"><b class="text-ink-900">Frissítések</b> automatikusan</span>
      </div>
      <div class="rounded-xl bg-white ring-1 ring-ink-200 px-4 py-3.5 flex items-center gap-2.5 fade-up" style="transition-delay: 90ms">
        <i data-lucide="file-down" class="w-4 h-4 text-leaf-600 shrink-0"></i>
        <span class="text-xs text-ink-700"><b class="text-ink-900">Adatexport</b> bármikor</span>
      </div>
    </div>
  </div>
</section>
