---
import Base from "../layouts/Base.astro";
import Hero from "../components/Hero.astro";
import Stats from "../components/Stats.astro";
import Reviews from "../components/Reviews.astro";
import WhatItIs from "../components/WhatItIs.astro";
import ModulMap from "../components/ModulMap.astro";
import FeaturesGrid from "../components/FeaturesGrid.astro";
import Replaces from "../components/Replaces.astro";
import RoiCalculator from "../components/RoiCalculator.astro";
import Personas from "../components/Personas.astro";
import Pricing from "../components/Pricing.astro";
import FaqMini from "../components/FaqMini.astro";
import Cta from "../components/Cta.astro";

const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": "https://boxbook.hu/#organization",
      "name": "BoxBook",
      "url": "https://boxbook.hu",
      "logo": "https://boxbook.hu/favicon.svg",
      "email": "info@boxbook.hu",
      "areaServed": "HU",
      "knowsLanguage": ["hu"],
    },
    {
      "@type": "WebSite",
      "@id": "https://boxbook.hu/#website",
      "url": "https://boxbook.hu",
      "name": "BoxBook",
      "inLanguage": "hu",
    },
    {
      "@type": "SoftwareApplication",
      "name": "BoxBook",
      "applicationCategory": "BusinessApplication",
      "applicationSubCategory": "BookingSystem",
      "operatingSystem": "Web, iOS, Android",
      "description": "Mosóállás-alapú online foglalási rendszer autókozmetikáknak.",
      "url": "https://boxbook.hu",
      "offers": [
        { "@type": "Offer", "name": "Starter", "price": "9900", "priceCurrency": "HUF" },
        { "@type": "Offer", "name": "Pro", "price": "14900", "priceCurrency": "HUF" },
      ],
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.83",
        "reviewCount": "6",
        "bestRating": "5",
      },
    },
  ],
};
---

<Base structuredData={structuredData}>
  <Hero />
  <Stats />
  <!-- Reviews FÖL HÚZVA — Pricing előtti társadalmi bizonyíték -->
  <Reviews />
  <WhatItIs />
  <ModulMap />
  <FeaturesGrid />
  <Replaces />
  <RoiCalculator />

  <!-- Esettanulmány teaser → részletes a /esettanulmanyok aloldalon -->
  <section class="relative bg-white">
    <div class="mx-auto max-w-7xl px-5 lg:px-8 py-20 lg:py-24">
      <a href="/esettanulmanyok" class="block fade-up group rounded-3xl bg-ink-50 ring-1 ring-ink-200 hover:ring-leaf-300 hover:-translate-y-0.5 transition-all overflow-hidden">
        <div class="grid lg:grid-cols-12 gap-6 lg:gap-10 p-8 lg:p-10 items-center">
          <div class="lg:col-span-7">
            <span class="inline-flex items-center gap-2 rounded-full bg-white ring-1 ring-ink-200 text-ink-700 px-3 py-1 text-[11px] font-bold tracking-widest uppercase">
              <i data-lucide="chart-no-axes-combined" class="w-3 h-3"></i>
              Esettanulmány
            </span>
            <h2 class="mt-5 text-3xl lg:text-5xl font-extrabold tracking-tightest text-balance leading-[1.05]">
              90 nap, <span class="grad-text-strong">+1.1 M Ft havi bevétel.</span>
            </h2>
            <p class="mt-4 text-ink-600 text-lg">
              Egy belvárosi szalon — AutoGloss Stúdió — valós számai a BoxBook foglaló + Növekedés marketing-csomag bevezetése után.
            </p>
            <span class="mt-5 inline-flex items-center gap-1.5 text-sm font-bold text-ink-900 group-hover:gap-2 transition-all">
              Teljes esettanulmány + 2 másik szegmens
              <i data-lucide="arrow-right" class="w-4 h-4"></i>
            </span>
          </div>
          <div class="lg:col-span-5 grid grid-cols-2 gap-3">
            <div class="rounded-xl bg-white ring-1 ring-ink-200 p-4">
              <div class="text-[10px] uppercase tracking-widest text-leaf-700 font-extrabold">Foglalás</div>
              <div class="mt-1 text-2xl font-extrabold tracking-tightest grad-text-strong">+47%</div>
            </div>
            <div class="rounded-xl bg-white ring-1 ring-ink-200 p-4">
              <div class="text-[10px] uppercase tracking-widest text-leaf-700 font-extrabold">Bevétel</div>
              <div class="mt-1 text-2xl font-extrabold tracking-tightest grad-text-strong">+1.1M</div>
            </div>
            <div class="rounded-xl bg-white ring-1 ring-ink-200 p-4">
              <div class="text-[10px] uppercase tracking-widest text-leaf-700 font-extrabold">No-show</div>
              <div class="mt-1 text-2xl font-extrabold tracking-tightest grad-text-strong">−67%</div>
            </div>
            <div class="rounded-xl bg-white ring-1 ring-ink-200 p-4">
              <div class="text-[10px] uppercase tracking-widest text-leaf-700 font-extrabold">Google ★</div>
              <div class="mt-1 text-2xl font-extrabold tracking-tightest text-ink-900">+0.6</div>
            </div>
          </div>
        </div>
      </a>
    </div>
  </section>

  <Personas />
  <Pricing />
  <FaqMini />
  <Cta />
</Base>
